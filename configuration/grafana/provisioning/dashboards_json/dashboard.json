          "query": "import \"array\"\n\n// TABLE CORRESPONDANCES gateway EUI => nom\ngtwNames = array.from(rows: [\n  ${map_gateways:csv}\n])\n|> group()\n\nalerts = from(bucket: \"${INFLUXDB_BUCKET}\")\n  |> range(start: -30d)\n  |> filter(fn: (r) => r._measurement == \"gateway_alerts\")\n  |> group(columns: [\"devEui\", \"alertId\"])\n  |> sort(columns: [\"_time\"], desc: false)\n  |> last()\n  |> filter(fn: (r) => r._value == 1)\n  |> keep(columns: [\"_time\", \"_value\", \"devEui\", \"alertType\", \"severity\"])\n  |> group()\n\njoin(\n    tables: {a: gtwNames, b: alerts},\n    on: [\"devEui\"]\n)\n|> map(fn: (r) => ({\n    Passerelle: r.name,\n    Type: r.alertType,\n    Depuis: r._time,\n    Gravite: r.severity\n}))\n|> yield(name: \"gtw_alerts\")",
          "refId": "A"
        }
      ],
      "title": "Alertes actives des passerelles déconnectées",
