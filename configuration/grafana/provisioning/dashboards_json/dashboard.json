          "rawQuery": true,
          "rawSql": "SELECT\n    d.name AS \"Nom du Pommeau\",\n    d.last_seen_at AS \"Dernière Activité\",\n    a.name AS \"Lieu\",\n    d.tags->>'location' AS \"Emplacement\"\nFROM device d\nJOIN application a ON d.application_id = a.id\nJOIN device_profile dp ON d.device_profile_id = dp.id\nWHERE dp.name ILIKE '%showerhead%'\nORDER BY a.name ASC, d.name ASC;",
