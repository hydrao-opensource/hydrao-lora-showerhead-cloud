          "datasource": {
            "type": "influxdb",
            "uid": "P2C2B70520A8E42FD"
          },
          "query": "\nimport \"array\"\nimport \"join\"\n\n// TABLE CORRESPONDANCES devEUI => label (pommeaux de douche)\ndeviceNames = array.from(rows: [\n  ${map_showerheads:csv}\n])\n|> group()\n\n// VOLUMES DATA\nrealData = from(bucket: \"${INFLUXDB_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"showers\")\n  |> filter(fn: (r) => r._field == \"volume\")\n  |> filter(fn: (r) => contains(value: r.devEui, set: ${showerhead:json}))\n  |> aggregateWindow(every: ${interval}, fn: sum, createEmpty: false)\n  |> group()\n\n// Ancre : évite l'erreur \"empty left table\" si aucune donnée douche n'existe encore\nanchor = array.from(rows: [{\n    _time: 1970-01-01T00:00:00Z,\n    _value: 0.0,\n    devEui: \"0000000000000000\"\n}])\n|> group()\n\ndata = union(tables: [realData, anchor])\n\n// JOIN VOLUME WITH DEVICE NAME\njoin.left(\n    left: data,\n    right: deviceNames,\n    on: (l, r) => l.devEui == r.devEui,\n    as: (l, r) => ({ \n        l with \n        _field: if exists r.name then r.name else l.devEui \n    })\n)\n    |> filter(fn: (r) => r.devEui != \"0000000000000000\")\n    |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n    |> group(columns: [\"_field\"])\n    |> yield(name: \"conso\")",
          "refId": "A"
        }
      ],
      "title": "Consommation d'eau des douches (Dans la période)",
      "type": "timeseries"
