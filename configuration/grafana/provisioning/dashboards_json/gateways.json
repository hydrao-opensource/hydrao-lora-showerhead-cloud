        {
          "query": "import \"array\"\n\n// 1. TABLE DES CORRESPONDANCES\ngtwNames = array.from(rows: [ ${map_gateways:csv} ])\n  |> group()\n\n// 2. FUSION PAR ALERT_ID\nalerts = from(bucket: \"${INFLUXDB_BUCKET}\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"gateway_alerts\")\n  |> group(columns: [\"alertId\", \"devEui\", \"alertType\"])\n  |> sort(columns: [\"_time\"], desc: false)\n  |> reduce(\n      fn: (r, accumulator) => ({\n          debut: if r._value == 1 then r._time else accumulator.debut,\n          fin: if r._value == 0 then r._time else accumulator.fin,\n          devEui: r.devEui,\n          alertType: r.alertType\n      }),\n      identity: {debut: time(v: \"0001-01-01T00:00:00Z\"), fin: time(v: \"0001-01-01T00:00:00Z\"), devEui: \"\", alertType: \"\"}\n  )\n  |> group()\n\n// 3. JOINTURE ET CALCULS FINAUX\njoin(\n    tables: {a: gtwNames, b: alerts},\n    on: [\"devEui\"]\n)\n|> map(fn: (r) => {\n    isTerminee = r.fin != time(v: \"0001-01-01T00:00:00Z\")\n    dateDebut = if r.debut != time(v: \"0001-01-01T00:00:00Z\") then r.debut else r.fin\n    \n    return {\n        Passerelle: r.name,\n        Debut: dateDebut,\n        Fin: if isTerminee then int(v: uint(v: r.fin) / uint(v: 1000000)) else 0,\n        Statut: if isTerminee then \"Terminée\" else \"EN COURS ⚠️\",\n        \"Duree (min)\": if isTerminee then float(v: uint(v: r.fin) - uint(v: dateDebut)) / 60000000000.0 else 0.0\n    }\n})\n|> sort(columns: [\"Debut\"], desc: true)",
          "refId": "A"
        }
      ],
      "title": "Historique des déconnexions",
